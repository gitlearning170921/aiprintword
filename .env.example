# 复制本文件为 .env 并填写；.env 已在 .gitignore 中，勿提交仓库。
# 配置 MYSQL_HOST 后，签名页「保存到列表」与「生成已签名文档」结果均写入 MySQL，多台电脑共用列表并可下载已签名文件。

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_DATABASE=aiprintword_sign

# 库中最多保留的待签文件条数（可选，默认 500）
# SIGN_MYSQL_MAX_FILES=500

# 已签名结果最多条数（可选，默认 2000）；超出需先在页面上删除旧记录
# SIGN_MYSQL_MAX_SIGNED=2000
