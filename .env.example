# 复制本文件为 .env 并填写；.env 已在 .gitignore 中，勿提交仓库。
# 若服务启动工作目录与 app.py 不在同一盘符/目录，可在系统环境变量中设置 AIPRINTWORD_DOTENV_PATH=绝对路径\.env
# 配置 MYSQL_HOST 后，签名页「保存到列表」、签署人笔迹库、每文件「角色→签署人」映射、已签名结果均写入 MySQL；「一键批量签」仅在此模式下可用。

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_DATABASE=aiprintword_sign

# FTP（上传文件与已签名产物存储；MySQL 仅存记录）
FTP_HOST=10.26.1.221
FTP_PORT=2121
FTP_USER=aiwordftpuser
FTP_PASSWORD=
# FTP_BASE_DIR：父目录；程序会在其下自动创建 FTP_APP_DIR
FTP_BASE_DIR=/upload
FTP_APP_DIR=aiprintword

# 系统设置页 /settings 与保存运行时配置（须与 MYSQL_HOST 等同时配置后方可写库）
AIPRINTWORD_ADMIN_TOKEN=
# 若 Web 服务迟迟不读 .env（仍为旧版 app），可在 Windows「系统环境变量」里直接新增同名用户/系统变量后重启服务进程
# 或单行口令文件路径（可选，与上一行二选一）
# AIPRINTWORD_ADMIN_TOKEN_FILE=C:\path\to\admin_token.txt
# 也可在项目下创建 data/admin_token.txt（仅一行口令，已加入 .gitignore）

# 库中最多保留的待签文件条数（可选，默认 500）
# SIGN_MYSQL_MAX_FILES=500

# 已签名结果最多条数（可选，默认 2000）；超出需先在页面上删除旧记录
# SIGN_MYSQL_MAX_SIGNED=2000

# Word：主文档表格行合计（docx XML 计数）≥此值走轻量处理路径，默认 100
# WORD_MANY_TABLE_ROWS_LITE_THRESHOLD=100

# 批处理上传 .7z / .rar：可选指定 7-Zip、UnRAR 可执行文件路径（否则在 PATH 与常见安装目录中查找；.7z 无 7z.exe 时可依赖 pip 的 py7zr）
# SEVEN_ZIP_EXE=C:\Program Files\7-Zip\7z.exe
# UNRAR_EXE=C:\Program Files\WinRAR\UnRAR.exe
