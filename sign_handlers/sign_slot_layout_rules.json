  "layout_priority_rules": [
    {
      "layout_type": "two_row_signoff_table",
      "priority": 100,
      "match_contains": [
        "两行签批表"
      ],
      "description": "两行签批表优先按角色行/日期行固定落位"
    },
    {
      "layout_type": "same_cell_inline",
      "priority": 80,
      "match_contains": [
        "同字段长空格占位",
        "同字段下划线/点线占位"
      ],
      "description": "同字段占位优先同格内联插入"
    },
    {
      "layout_type": "adjacent_right_cell",
      "priority": 60,
      "match_contains": [
        "右侧空白单元格",
        "日期在右相邻单元格",
        "日期在右侧隔列单元格"
      ],
      "description": "优先右侧相邻/隔列空白格"
    }
  ],
  "signature_slot_forms": [
    "右侧空白单元格",
    "右侧已有姓名/日期值（需先删除电脑输入后重签）",
    "同字段长空格占位",
    "同字段下划线/点线占位",
    "两行签批表：角色行右侧空白签名格，日期行右侧空白日期格"
