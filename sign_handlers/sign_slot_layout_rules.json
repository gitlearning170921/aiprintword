      "priority": 80,
      "match_contains": [
        "同字段长空格占位",
        "同字段下划线/点线占位"
      ],
      "description": "同字段占位优先同格内联插入"
    },
    {
      "layout_type": "adjacent_right_cell",
      "priority": 60,
      "match_contains": [
        "右侧空白单元格",
        "日期在右相邻单元格",
        "日期在右侧隔列单元格"
      ],
      "description": "优先右侧相邻/隔列空白格"
    }
  ],
