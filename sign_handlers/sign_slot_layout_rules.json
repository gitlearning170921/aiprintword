{
  "schema_version": 1,
  "signature_slot_forms": [
    "右侧空白单元格",
    "右侧已有姓名/日期值（需先删除电脑输入后重签）",
    "同字段长空格占位",
    "同字段下划线/点线占位",
    "两行签批表：角色行右侧空白签名格，日期行右侧空白日期格"
  ],
  "date_layout_forms": [
    "日期在下方相邻/偏右单元格",
    "日期在右相邻单元格",
    "与角色同一单元格/字段标记",
    "日期在右侧隔列单元格",
    "与角色同字段标记，后接长空格",
    "与角色同字段标记，后接下划线/点线",
    "日期在下一行对应签名格右侧/同列空白格（两行签批表）"
  ],
  "replace_prefilled_slot": {
    "enabled": true,
    "max_text_len": 48,
    "fullmatch_patterns": [
      "^[\\u4e00-\\u9fff]{2,4}$",
      "^[A-Za-z][A-Za-z\\s]{1,30}$",
      "^\\d{4}[./-]\\d{1,2}(?:[./-]\\d{1,2})?$",
      "^[\\u4e00-\\u9fff]{2,4}\\s*[/｜|]\\s*\\d{4}[./-]\\d{1,2}(?:[./-]\\d{1,2})?$"
    ],
    "search_patterns": [
      "\\d{4}[./-]\\d{1,2}(?:[./-]\\d{1,2})?",
      "[\\u4e00-\\u9fff]{2,4}\\s*[/｜|]\\s*\\d{4}[./-]\\d{1,2}"
    ]
  }
}
